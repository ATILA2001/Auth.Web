@page "/Account/AccessDenied"

<PageTitle>Acceso Denegado</PageTitle>

<RadzenStack Orientation="Orientation.Vertical" 
             AlignItems="AlignItems.Center" 
             JustifyContent="JustifyContent.Center"
             Gap="1.5rem"
             Class="rz-p-4">
    <RadzenIcon Icon="block" Style="font-size: 4rem; color: var(--rz-danger);" />
    
    <RadzenHeading Size="HeadingSize.H3" 
                   Text="Acceso Denegado" 
                   Class="rz-text-align-center" />
    
    <RadzenAlert Severity="AlertSeverity.Error" 
                 Variant="Variant.Flat"
                 AllowClose="false"
                 Style="width: 100%; max-width: 600px;">
        No tiene permiso para acceder a este recurso.
    </RadzenAlert>
    
    <RadzenButton Text="Volver al Inicio" 
                  Icon="home"
                  ButtonStyle="ButtonStyle.Secondary"
                  Click="@(() => NavigationManager.NavigateTo("/Account/Login"))" />
</RadzenStack>

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
}
