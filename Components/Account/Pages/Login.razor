@page "/Account/Login"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Inicio de sesion</PageTitle>

<RadzenStack Style="min-height:100vh" AlignItems="Radzen.AlignItems.Center" JustifyContent="Radzen.JustifyContent.Center">
    <RadzenCard Style="width:100%; max-width:460px;">
        <RadzenTabs @bind-Value="selectedTabIndex">
            <Tabs>
                <RadzenTabsItem Text="Iniciar sesión">
                    <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="20">
                        <RadzenLabel Text="Use sus credenciales de Windows para iniciar sesión." />
                        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                        {
                            <RadzenAlert Severity="Radzen.AlertSeverity.Error" Style="width:100%">@ErrorMessage</RadzenAlert>
                        }
                        @if (!string.IsNullOrWhiteSpace(SuccessMessage))
                        {
                            <RadzenAlert Severity="Radzen.AlertSeverity.Success" Style="width:100%">@SuccessMessage</RadzenAlert>
                        }

                        <form method="post" action="/connect/login">
                            <input name="UserNameOrEmail" placeholder="Correo electrónico / CUIL" style="width:100%" @bind="Input.UserNameOrEmail" />
                            <input name="Password" type="password" placeholder="Contraseña" style="width:100%" @bind="Input.Password" />
                            <input type="hidden" name="ReturnUrl" value="@ReturnUrlFromQuery" />
                            <input type="hidden" name="ClientId" value="@ClientIdFromQuery" />
                            <button type="submit" class="rz-button rz-primary" style="width:100%; margin-top:12px">Iniciar</button>
                        </form>
                    </RadzenStack>
                </RadzenTabsItem>
                <RadzenTabsItem Text="Registrarse">
                    <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="20">
                        @if (!string.IsNullOrWhiteSpace(RegisterMessage))
                        {
                            <RadzenAlert Severity="Radzen.AlertSeverity.Error" Style="width:100%">@RegisterMessage</RadzenAlert>
                        }
                        <EditForm Model="@RegInput" OnValidSubmit="@RegisterUser">
                            <DataAnnotationsValidator />
                            <ValidationSummary />
                            <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="20">
                                <RadzenTextBox @bind-Value="RegInput.FullName" Placeholder="Nombre completo" Style="width:100%" />
                                <RadzenTextBox @bind-Value="RegInput.Email" Placeholder="Correo electrónico" Style="width:100%" />
                                <RadzenButton ButtonStyle="Radzen.ButtonStyle.Primary" Text="Registrarse" Type="Radzen.ButtonType.Submit" Style="width:100%" />
                            </RadzenStack>
                        </EditForm>
                    </RadzenStack>
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    </RadzenCard>
    <RadzenLink Text="¿No tienes cuenta? Regístrate" Click="@(() => selectedTabIndex = 1)" Style="margin-top:8px" />
</RadzenStack>
