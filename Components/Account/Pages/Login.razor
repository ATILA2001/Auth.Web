@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using Auth.Web.Data
@using Auth.Web.Services.Abstractions

@inject HttpClient Http
@inject UserManager<ApplicationUser> UserManager
@inject IAdAuthService AdAuth
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IRoutingService Routing

<PageTitle>Log in</PageTitle>

<h1>Log in</h1>
<div class="row">
    <div class="col-md-4">
        <section>
            <StatusMessage Message="@errorMessage" />
            <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                <DataAnnotationsValidator />
                <h2>Use your Active Directory account to log in.</h2>
                <hr />
                <ValidationSummary class="text-danger" role="alert" />
                <div class="form-floating mb-3">
                    <InputText @bind-Value="Input.UserNameOrEmail" class="form-control" autocomplete="username" aria-required="true" placeholder="user or user@domain" />
                    <label for="username" class="form-label">User or email</label>
                    <ValidationMessage For="() => Input.UserNameOrEmail" class="text-danger" />
                </div>
                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label for="password" class="form-label">Password</label>
                    <ValidationMessage For="() => Input.Password" class="text-danger" />
                </div>
                <div class="checkbox mb-3">
                    <label class="form-label">
                        <InputCheckbox @bind-Value="Input.RememberMe" class="darker-border-checkbox form-check-input" />
                        Remember me
                    </label>
                </div>
                <div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div>
                <div>
                    <p>
                        <a href="Account/Register">Register as a new user</a>
                    </p>
                </div>
            </EditForm>
        </section>
    </div>
</div>

@code {
    private string? errorMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    public async Task LoginUser()
    {
        errorMessage = null;

        var login = Input.UserNameOrEmail.Trim();
        var password = Input.Password;

        // 1) Validar contra AD
        var adOk = await AdAuth.ValidateAsync(login, password);
        if (!adOk)
        {
            errorMessage = "Error: Invalid login attempt (AD).";
            return;
        }

        // 2) Buscar usuario local por UserName o Email (registro previo requerido)
        var user = await UserManager.FindByNameAsync(login) ?? await UserManager.FindByEmailAsync(login);
        if (user is null)
        {
            errorMessage = "Error: No local account found. Please register first.";
            return;
        }

        // 3) Resolver destino por áreas (BD)
        var target = await Routing.ResolveForUserAsync(user.Id);
        if (target is null)
        {
            errorMessage = "No hay una regla de redirección para tu usuario/áreas.";
            return;
        }

        // 4) Solicitar token y redirigir
        var payload = new
        {
            UserName = login,
            Password = password,
            ClientId = target.Value.ClientId,
            ReturnUrl = target.Value.ReturnUrl,
            DisplayName = (string?)null
        };

        try
        {
            var uri = NavigationManager.ToAbsoluteUri("/connect/login").ToString();
            var response = await Http.PostAsJsonAsync(uri, payload);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();
                if (string.IsNullOrWhiteSpace(errorMessage))
                {
                    errorMessage = $"Login error ({(int)response.StatusCode}).";
                }
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<LoginResultDto>();
            if (result is null || string.IsNullOrWhiteSpace(result.Redirect))
            {
                errorMessage = "Respuesta inválida del servidor.";
                return;
            }

            NavigationManager.NavigateTo(result.Redirect, forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error de comunicación: {ex.Message}";
        }
    }

    private sealed class InputModel
    {
        [Required]
        public string UserNameOrEmail { get; set; } = string.Empty;

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }

    private sealed class LoginResultDto
    {
        public string? Redirect { get; set; }
    }
}
