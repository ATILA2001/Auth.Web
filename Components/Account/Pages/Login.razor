@page "/Account/Login"
@rendermode InteractiveServer

<PageTitle>Inicio de sesion</PageTitle>

<div class="container-fluid vh-100 d-flex justify-content-center align-items-center">
    <div class="row justify-content-center w-100">
        <div class="col-11 col-sm-8 col-md-6 col-lg-4">
            <RadzenCard Class="rz-shadow-3 rz-p-4">
                <RadzenTabs @bind-Value="selectedTabIndex">
                    <Tabs>
                        <RadzenTabsItem Text="INICIAR SESIÓN">
                            <ChildContent>
                                <RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem">
                                    <RadzenLabel Text="Use sus credenciales de Windows para iniciar sesión." />

                                    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                                    {
                                        <RadzenAlert Severity="AlertSeverity.Error" Style="width:100%">@ErrorMessage</RadzenAlert>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
                                    {
                                        <RadzenAlert Severity="AlertSeverity.Success" Style="width:100%">@SuccessMessage</RadzenAlert>
                                    }

                                    <form method="post" action="/connect/login">
                                        <RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem">
                                            <RadzenTextBox Name="UserNameOrEmail"
                                                           Style="width:100%"
                                                           Placeholder="Correo electrónico / CUIL"
                                                           @bind-Value="Input.UserNameOrEmail" />

                                            <RadzenPassword Name="Password"
                                                            Style="width:100%"
                                                            Placeholder="Contraseńa"
                                                            @bind-Value="Input.Password" />

                                            <input type="hidden" name="ReturnUrl" value="@ReturnUrlFromQuery" />
                                            <input type="hidden" name="ClientId" value="@ClientIdFromQuery" />

                                            <RadzenButton ButtonType="ButtonType.Submit"
                                                          Text="Iniciar"
                                                          ButtonStyle="ButtonStyle.Primary"
                                                          Size="ButtonSize.Large"
                                                          class="w-100" />
                                        </RadzenStack>
                                    </form>
                                </RadzenStack>
                            </ChildContent>
                        </RadzenTabsItem>

                        <RadzenTabsItem Text="Registrarse">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem">
                                @if (!string.IsNullOrWhiteSpace(RegisterMessage))
                                {
                                    <RadzenAlert Severity="AlertSeverity.Error" Style="width:100%">@RegisterMessage</RadzenAlert>
                                }
                                <EditForm Model="@RegInput" OnValidSubmit="@RegisterUser">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary />
                                    <RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem">
                                        <RadzenTextBox @bind-Value="RegInput.FullName"
                                                       Placeholder="Nombre completo"
                                                       Style="width:100%" />
                                        <RadzenTextBox @bind-Value="RegInput.Email"
                                                       Placeholder="Correo electrónico"
                                                       Style="width:100%" />
                                        <RadzenButton ButtonStyle="ButtonStyle.Primary"
                                                      Text="Registrarse"
                                                      Type="ButtonType.Submit"
                                                      class="w-100" />
                                    </RadzenStack>
                                </EditForm>
                            </RadzenStack>
                        </RadzenTabsItem>
                    </Tabs>
                </RadzenTabs>
            </RadzenCard>
        </div>
    </div>
</div>