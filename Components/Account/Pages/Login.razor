@page "/Account/Login"
@rendermode InteractiveServer

@using Auth.Web.Components.Account.Pages
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Inicio de sesion</PageTitle>

<RadzenStack Style="min-height:100vh" AlignItems="Radzen.AlignItems.Center" JustifyContent="Radzen.JustifyContent.Center">
    <RadzenCard Style="width:100%; max-width:420px;">
        <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="2">
            <RadzenLabel Text="Use sus credenciales de Windows para iniciar sesión." />
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <RadzenAlert Severity="Radzen.AlertSeverity.Error" Style="width:100%">@ErrorMessage</RadzenAlert>
            }
            <EditForm Model="@Input" OnValidSubmit="@ExecuteLogin">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="2">
                    <RadzenTextBox @bind-Value="Input.UserNameOrEmail" Placeholder="Correo electrónico / CUIL" Style="width:100%" />
                    <RadzenPassword @bind-Value="Input.Password" Placeholder="Contraseña" Style="width:100%" />
                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="Radzen.AlignItems.Center" Gap="1">
                        <RadzenCheckBox @bind-Value="Input.RememberMe" />
                        <RadzenLabel Text="Recordar" />
                    </RadzenStack>
                    <RadzenButton ButtonStyle="Radzen.ButtonStyle.Primary" Text="Iniciar" Type="Radzen.ButtonType.Submit" Style="width:100%" />
                </RadzenStack>
            </EditForm>
        </RadzenStack>
    </RadzenCard>
</RadzenStack>
