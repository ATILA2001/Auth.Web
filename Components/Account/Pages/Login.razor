@page "/Account/Login"
@rendermode InteractiveServer

<PageTitle>Inicio de sesión</PageTitle>

<link href="css/login.css" rel="stylesheet" />

<div class="login-background" style="@BackgroundStyle">
    <div class="login-card">
        <div class="row g-0">
            <!-- Left panel - Logo -->
            <div class="col-md-5 login-left-panel">
                <img src="images/IVC-Blanco.png" alt="Logo" class="login-logo" />
            </div>

            <!-- Right panel with flip container -->
            <div class="col-md-7 login-right-panel">
                <div class="flip-container @(IsFlipped ? "flipped" : "")">
                    <div class="flipper">
                        <!-- Front side - Login -->
                        <div class="front login-form-content">
                            <h1>Iniciá sesión</h1>
                        
                            <form method="post" action="/connect/login" id="loginForm">
                                <div class="login-field">
                                    <RadzenFormField Text="CUIL o Correo electrónico" Variant="Variant.Outlined" Style="width:100%">
                                        <RadzenTextBox Name="UserNameOrEmail" Placeholder="Ingrese su CUIL o correo electrónico" @bind-Value="loginUser" Style="width:100%" />
                                    </RadzenFormField>
                                </div>

                                <div class="login-field">
                                    <RadzenFormField Text="Contraseña" Variant="Variant.Outlined" Style="width:100%">
                                        <RadzenPassword Name="Password" Placeholder="Ingrese su contraseña" Style="width:100%" />
                                    </RadzenFormField>
                                </div>

                                <input type="hidden" name="ReturnUrl" value="@(ReturnUrlFromQuery ?? string.Empty)" />
                                <input type="hidden" name="ClientId" value="@(ClientIdFromQuery ?? string.Empty)" />
                                @if (!string.IsNullOrEmpty(AntiforgeryFieldName) && !string.IsNullOrEmpty(AntiforgeryToken))
                                {
                                    <input type="hidden" name="@AntiforgeryFieldName" value="@AntiforgeryToken" />
                                }
                            </form>

                            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                            {
                                <div class="validation-message" style="margin-top: 0.5rem;">@ErrorMessage</div>
                            }

                            <div class="login-form-footer">
                                <RadzenButton Text="Crear una cuenta" Variant="Variant.Text" Click="FlipCard" ButtonStyle="ButtonStyle.Base" />
                                <RadzenButton Text="Ingresar" ButtonType="ButtonType.Submit" form="loginForm" ButtonStyle="ButtonStyle.Dark" />
                            </div>
                        </div>

                        <!-- Back side - Register -->
                        <div class="back login-form-content">
                            <h1>Registro de usuario</h1>
                            
                            <EditForm Model="@RegInput" OnValidSubmit="@RegisterUser" FormName="registerForm">
                                <DataAnnotationsValidator />
                                
                                <div class="login-field">
                                    <RadzenFormField Text="CUIL" Variant="Variant.Outlined" Style="width:100%">
                                        <RadzenTextBox @bind-Value="RegInput.Cuil" Placeholder="Ej: 20123456789" Style="width:100%" />
                                    </RadzenFormField>
                                    <ValidationMessage For="@(() => RegInput.Cuil)" />
                                </div>

                                <div class="login-field">
                                    <RadzenFormField Text="Correo electrónico" Variant="Variant.Outlined" Style="width:100%">
                                        <RadzenTextBox @bind-Value="RegInput.Email" Placeholder="Email@Ejemplo.com" Style="width:100%" />
                                    </RadzenFormField>
                                    <ValidationMessage For="@(() => RegInput.Email)" />
                                </div>

                                @if (!string.IsNullOrWhiteSpace(RegisterMessage))
                                {
                                    <div class="validation-message" style="margin-top: 0.5rem;">@RegisterMessage</div>
                                }

                                <div class="login-form-footer">
                                    <RadzenButton Text="Volver a iniciar sesión" Variant="Variant.Text" Click="FlipCard" ButtonStyle="ButtonStyle.Base" />
                                    <RadzenButton Text="Registrar" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Dark" />
                                </div>
                            </EditForm>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>