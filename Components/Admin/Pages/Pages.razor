@page "/admin/pages"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Pages

<RadzenHeading Size="HeadingSize.H3"
               Text="Páginas"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">

            @if (editing)
            {
                <div class="rz-mb-3">
                    <RadzenTemplateForm TItem="PageFormModel" Data="@pageForm">

                        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                            <RadzenLabel Text="@(editModel.Id == 0 ? "Nueva Página" : "Editar Página")" Style="font-weight: bold;" />

                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                <RadzenLabel Text="Nombre" Component="pageNameInput" />
                                <RadzenTextBox Name="pageNameInput" @bind-Value="pageForm.Name" Placeholder="Nombre" Style="width: 100%" />
                                <RadzenRequiredValidator Component="pageNameInput" Text="Requerido" />
                            </RadzenStack>

                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                <RadzenLabel Text="URL" Component="pageUrlInput" />
                                <RadzenTextBox Name="pageUrlInput" @bind-Value="pageForm.Url" Placeholder="URL (ej: /admin/users)" Style="width: 100%" />
                                <RadzenRequiredValidator Component="pageUrlInput" Text="Requerido" />
                            </RadzenStack>

                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@OnSubmitPage" />
                                <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@CancelEdit" />
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenTemplateForm>
                </div>
            }
            else
            {
                <div class="rz-mb-3">
                    <RadzenButton Text="Agregar" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@BeginCreate" />
                </div>
            }

            <RadzenDataGrid TItem="Application.Admin.Dtos.PageAdminDto" Data="@pages" @ref="grid" AllowPaging="true" PageSize="10" AllowFiltering="true" AllowColumnResize="true"
                FilterMode="FilterMode.CheckBoxList" AllowSorting="true" ClearFilterText="Limpiar" ApplyFilterText="Aplicar" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                AllowColumnPicking="false" ColumnsText="Columnas" ColumnsShowingText="columnas mostradas" AllColumnsText="Todas" EmptyText="Sin registros">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.PageAdminDto" Property="Name" Title="Nombre" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.PageAdminDto" Property="Url" Title="URL" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.PageAdminDto" Property="PermissionCount" Title="Permisos" Width="100px" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.PageAdminDto" Context="p" Width="160px">
                        <Template Context="p">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Title="Editar" AriaLabel="Editar" Click="@(args => BeginEdit(p))" Disabled="@editing" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" class="rz-ml-2" Title="Eliminar" AriaLabel="Eliminar" Click="@(args => DeletePage(p.Id))" Disabled="@editing" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
