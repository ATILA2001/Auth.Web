@page "/admin/pages"
@using Microsoft.AspNetCore.Authorization
@using Auth.Web.Application.Admin.Dtos
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Pages

<RadzenHeading Size="HeadingSize.H3"
               Text="Páginas"
               Class="rz-mb-3" />

@if (IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 100%;" />
}

<RadzenDataGrid TItem="PageAdminDto" Data="@pages" @ref="grid" IsBusy="@IsLoading" AllowPaging="false" AllowVirtualization="true" AllowFiltering="true" AllowColumnResize="true"
                            AllowSorting="true" EditMode="DataGridEditMode.Single" RowCreate="@OnRowCreate" RowUpdate="@OnRowUpdate"
                            FilterMode="FilterMode.CheckBoxList" ClearFilterText="Limpiar" ApplyFilterText="Aplicar"
                            GridLines="DataGridGridLines.Both" AllowColumnPicking="false" ColumnsText="Columnas"
                             ColumnsShowingText="columnas mostradas" AllColumnsText="Todas"
                            EmptyText="No hay registros para mostrar.">
                <HeaderTemplate>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                        <RadzenButton ButtonStyle="ButtonStyle.Success" Icon="add_circle" Text="Agregar" Click="@BeginCreate" Disabled="@(IsLoading || IsSaving || _pagesToInsert.Count > 0)" />
                        <RadzenButton Icon="filter_alt_off" Text="Limpiar filtros" Click="@ClearFilters" Disabled="@(IsLoading || IsSaving)" />
                    </RadzenStack>
                </HeaderTemplate>
                <Columns>
                    <RadzenDataGridColumn TItem="PageAdminDto" Property="Name" Title="Nombre">
                        <EditTemplate Context="p">
                            <RadzenTextBox Value="@GetNameBuffer(p)" ValueChanged="@(v => SetNameBuffer(p, v))" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="PageAdminDto" Property="Url" Title="URL">
                        <EditTemplate Context="p">
                            <RadzenTextBox Value="@GetUrlBuffer(p)" ValueChanged="@(v => SetUrlBuffer(p, v))" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="PageAdminDto" Property="ClientName" Title="Aplicación">
                        <EditTemplate Context="p">
                            <RadzenDropDown TValue="int?"
                                            Data="@clients"
                                            TextProperty="ClientId"
                                            ValueProperty="Id"
                                            Placeholder="Sin asignar"
                                            Value="@GetClientBuffer(p)"
                                            ValueChanged="@(v => SetClientBuffer(p, v))"
                                            Disabled="@(IsLoading || IsSaving)"
                                            AllowClear="true" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="PageAdminDto" Property="PermissionCount" Title="Permisos" />
                    <RadzenDataGridColumn TItem="PageAdminDto" Context="p" Filterable="false" Title="Acciones" Width="112px" TextAlign="TextAlign.Center">
                        <Template Context="p">
                            <RadzenButton Icon="edit" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Editar" AriaLabel="Editar" Click="@(args => EditRow(p))" @onclick:stopPropagation class="rz-mr-2" Disabled="@(IsLoading || IsSaving)" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Eliminar" AriaLabel="Eliminar" Click="@(args => DeletePage(p.Id))" @onclick:stopPropagation Disabled="@(IsLoading || IsSaving)" />
                        </Template>
                        <EditTemplate Context="p">
                            <RadzenButton Icon="save" ButtonStyle="ButtonStyle.Success" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Guardar" AriaLabel="Guardar" Click="@(args => ValidateAndSave(p))" Disabled="@(IsLoading || IsSaving)" />
                            <RadzenButton Icon="cancel" ButtonStyle="ButtonStyle.Danger" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" class="rz-ml-2" Title="Cancelar" AriaLabel="Cancelar" Click="@(args => CancelEditRow(p))" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                </Columns>
</RadzenDataGrid>
