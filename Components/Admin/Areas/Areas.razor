@page "/admin/areas"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Areas

<RadzenHeading Size="HeadingSize.H3"
               Text="Áreas"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <div class="rz-mb-3">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                    <RadzenTextBox @bind-Value="newArea" Placeholder="Nueva área" Style="width: 300px" />
                    <RadzenButton Text="Crear" ButtonStyle="ButtonStyle.Primary" Disabled="@string.IsNullOrWhiteSpace(newArea)" Click="@(args => CreateArea())" />
                </RadzenStack>
            </div>

            <RadzenDataGrid TItem="Application.Admin.Dtos.AreaAdminDto" Data="@areas" @ref="grid" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="10" RowUpdate="@OnRowUpdate">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaAdminDto" Property="Name" Title="Nombre">
                        <EditTemplate Context="a">
                            <RadzenTextBox @bind-Value="a.Name" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaAdminDto" Property="UserCount" Title="Usuarios" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaAdminDto" Context="a" Width="160px">
                        <Template Context="a">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Click="@(args => grid.EditRow(a))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" class="rz-ml-2" Click="@(args => DeleteArea(a.Id))" />
                        </Template>
                        <EditTemplate Context="a">
                            <RadzenButton Icon="save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(args => grid.UpdateRow(a))" />
                            <RadzenButton Icon="cancel" Size="ButtonSize.Small" class="rz-ml-2" Click="@(args => grid.CancelEditRow(a))" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
