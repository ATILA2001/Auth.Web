@page "/admin/clients"
@using Microsoft.AspNetCore.Authorization
@using Auth.Web.Application.Admin.Dtos
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Clients

<RadzenHeading Size="HeadingSize.H3"
               Text="Aplicaciones"
               Class="rz-mb-3" />

@if (IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 100%;" />
}

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <RadzenDataGrid TItem="ApplicationClientAdminDto" Data="@clients" @ref="grid" AllowPaging="true" PageSize="10" AllowFiltering="true" AllowColumnResize="true"
                            AllowSorting="true" EditMode="DataGridEditMode.Single" RowCreate="@OnRowCreate" RowUpdate="@OnRowUpdate"
                            FilterMode="FilterMode.CheckBoxList" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                            AllowColumnPicking="false" EmptyText="No hay registros para mostrar.">
                <HeaderTemplate>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Icon="add_circle" Text="Agregar" Click="@BeginCreate" Disabled="@(IsLoading || IsSaving || _clientsToInsert.Count > 0)" />
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenButton ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Icon="filter_alt_off" Text="Limpiar filtros" Click="@ClearFilters" Disabled="@(IsLoading || IsSaving)" />
                        </RadzenStack>
                    </RadzenStack>
                </HeaderTemplate>
                <Columns>
                    <RadzenDataGridColumn TItem="ApplicationClientAdminDto" Property="ClientId" Title="ClientId">
                        <EditTemplate Context="c">
                            <RadzenTextBox Value="@GetClientIdBuffer(c)" ValueChanged="@(v => SetClientIdBuffer(c, v))" Style="width: 200px" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="ApplicationClientAdminDto" Property="Audience" Title="Audience">
                        <EditTemplate Context="c">
                            <RadzenTextBox Value="@GetAudienceBuffer(c)" ValueChanged="@(v => SetAudienceBuffer(c, v))" Style="width: 200px" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="ApplicationClientAdminDto" Title="ReturnUrls" Filterable="false">
                        <Template Context="c">@string.Join("; ", c.AllowedReturnUrls)</Template>
                        <EditTemplate Context="c">
                            <RadzenTextArea Value="@GetUrlsBuffer(c)" ValueChanged="@(v => SetUrlsBuffer(c, v))" Rows="4" Style="width: 280px" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="ApplicationClientAdminDto" Context="c" Filterable="false" Title="Acciones">
                        <Template Context="c">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Editar" AriaLabel="Editar" Click="@(args => EditRow(c))" @onclick:stopPropagation class="rz-mr-2" Disabled="@(IsLoading || IsSaving)" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Eliminar" AriaLabel="Eliminar" Click="@(args => DeleteClient(c.Id))" @onclick:stopPropagation Disabled="@(IsLoading || IsSaving)" />
                        </Template>
                        <EditTemplate Context="c">
                            <RadzenButton Icon="save" ButtonStyle="ButtonStyle.Primary" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Guardar" AriaLabel="Guardar" Click="@(args => ValidateAndSave(c))" Disabled="@(IsLoading || IsSaving)" />
                            <RadzenButton Icon="cancel" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" class="rz-ml-2" Title="Cancelar" AriaLabel="Cancelar" Click="@(args => CancelEditRow(c))" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
