@page "/admin/clients"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Clients

<RadzenHeading Size="HeadingSize.H3"
               Text="Aplicaciones"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <div class="rz-mb-3">
                <RadzenButton Text="Agregar" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@(() => BeginCreate())" />
            </div>

            <RadzenDataGrid TItem="Application.Admin.Dtos.ApplicationClientAdminDto" Data="@clients" AllowPaging="true" PageSize="10" AllowFiltering="true" AllowColumnResize="true"
                FilterMode="FilterMode.CheckBoxList" AllowSorting="true" ClearFilterText="Limpiar" ApplyFilterText="Aplicar" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                AllowColumnPicking="false" ColumnsText="Columnas" ColumnsShowingText="columnas mostradas" AllColumnsText="Todas">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ApplicationClientAdminDto" Property="ClientId" Title="ClientId" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ApplicationClientAdminDto" Property="Audience" Title="Audience" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ApplicationClientAdminDto" Title="ReturnUrls">
                        <Template Context="c">@string.Join("; ", c.AllowedReturnUrls)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ApplicationClientAdminDto" Context="c" Width="160px">
                        <Template Context="c">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Click="@(() => BeginEdit(c))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" class="rz-ml-2" Click="@(() => DeleteClient(c.Id))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

            @if (editing)
            {
                <div class="rz-mt-3">
                    <RadzenCard>
                        <RadzenFieldset Text="@(editModel.Id == 0 ? "Crear cliente" : $"Editar cliente {editModel.ClientId}")">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                                <RadzenTextBox @bind-Value="editModel.ClientId" Placeholder="ClientId" />
                                <RadzenTextBox @bind-Value="editModel.Audience" Placeholder="Audience" />
                                <RadzenLabel Text="Allowed Return Urls (una por línea)" />
                                <RadzenTextArea @bind-Value="allowedUrlsText" Rows="5" />
                                @if (!string.IsNullOrWhiteSpace(validationError))
                                {
                                    <RadzenAlert Severity="AlertSeverity.Error">@validationError</RadzenAlert>
                                }
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                                    <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" Click="@(() => SaveClient())" />
                                    <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@(() => CancelEdit())" />
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenFieldset>
                    </RadzenCard>
                </div>
            }
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
