@page "/admin/user-areas"
@using Auth.Web.Domain.Entities
@using Auth.Web.Services.Admin
@inject NavigationManager NavigationManager

<AuthorizeView Roles="Admin">
    <Authorized>
        <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="2">
            <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1">
                <RadzenButton Text="Volver" Icon="arrow_back" ButtonStyle="Radzen.ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/admin"))" />
                <RadzenHeading Size="Radzen.HeadingSize.H4" Text="Áreas por usuario" />
            </RadzenStack>

            <RadzenCard>
                <RadzenFieldset Text="Asignar área a usuario">
                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="Radzen.AlignItems.End" Gap="2">
                        <RadzenDropDown Data="@users" TextProperty="Email" ValueProperty="Id" @bind-Value="selectedUserId" FilterCaseSensitivity="Radzen.FilterCaseSensitivity.CaseInsensitive" AllowClear="true" AllowFiltering="true" Placeholder="Usuario (email)" Style="width:320px" />
                        <RadzenDropDown Data="@areas" TextProperty="Name" ValueProperty="Id" @bind-Value="selectedAreaId" Placeholder="Área" Style="width:240px" />
                        <RadzenButton Text="Asignar" ButtonStyle="Radzen.ButtonStyle.Primary" Disabled="@(!CanAssign)" Click="@(args => Assign())" />
                    </RadzenStack>
                </RadzenFieldset>
            </RadzenCard>

            <RadzenCard>
                <RadzenDataGrid TItem="UserArea" Data="@userAreas" AllowPaging="true" PageSize="10">
                    <Columns>
                        <RadzenDataGridColumn TItem="UserArea" Title="Usuario (email)">
                            <Template Context="ua">
                                @users.FirstOrDefault(u => u.Id == ua.UserId)?.Email
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UserArea" Title="Área">
                            <Template Context="ua">
                                @areas.FirstOrDefault(a => a.Id == ua.AreaId)?.Name
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UserArea" Context="ua" Width="120px">
                            <Template Context="ua">
                                <RadzenButton Icon="delete" ButtonStyle="Radzen.ButtonStyle.Danger" Size="Radzen.ButtonSize.Small" Click="@(args => Remove(ua.Id))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        </RadzenStack>
    </Authorized>
    <NotAuthorized>
        <RadzenAlert Severity="Radzen.AlertSeverity.Error">Acceso no autorizado.</RadzenAlert>
    </NotAuthorized>
</AuthorizeView>
