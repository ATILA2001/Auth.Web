@page "/admin/routes"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Routes

<RadzenHeading Size="HeadingSize.H3"
               Text="Rutas"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <div class="rz-mb-3">
                <RadzenButton Text="Nueva" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@(() => BeginCreate())" />
            </div>

            <RadzenDataGrid TItem="Application.Admin.Dtos.AreaRouteAdminDto" Data="@routes" AllowPaging="true" PageSize="10">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="AreaName" Title="Área" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="ApplicationName" Title="Cliente" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="ReturnUrl" Title="ReturnUrl" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="Priority" Title="Prioridad" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="IsActive" Title="Activo" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Context="r" Width="180px">
                        <Template Context="r">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Click="@(() => BeginEdit(r))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" class="rz-ml-2" Click="@(() => DeleteRoute(r.Id))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

            @if (editing)
            {
                <div class="rz-mt-3">
                    <RadzenCard>
                        <RadzenFieldset Text="@(editModel.Id == 0 ? "Crear ruta" : $"Editar ruta {editModel.Id}")">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                                <RadzenDropDown Data="@areas" TextProperty="Name" ValueProperty="Id" @bind-Value="selectedAreaId" Placeholder="Área" />
                                <RadzenDropDown Data="@clients" TextProperty="ClientId" ValueProperty="Id" @bind-Value="selectedClientId" Placeholder="Cliente" />
                                <RadzenTextBox @bind-Value="editReturnUrl" Placeholder="ReturnUrl" />
                                <RadzenNumeric @bind-Value="editPriority" Placeholder="Prioridad" />
                                <RadzenCheckBox @bind-Value="editIsActive" /> <RadzenLabel Text="Activo" />
                                @if (!string.IsNullOrWhiteSpace(validationError))
                                {
                                    <RadzenAlert Severity="AlertSeverity.Error">@validationError</RadzenAlert>
                                }
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                                    <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" Click="@(() => SaveRoute())" />
                                    <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@(() => CancelEdit())" />
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenFieldset>
                    </RadzenCard>
                </div>
            }
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
