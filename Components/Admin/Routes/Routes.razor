@page "/admin/routes"
@using Microsoft.AspNetCore.Authorization
@using Auth.Web.Application.Admin.Dtos
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Routes

<RadzenHeading Size="HeadingSize.H3"
               Text="Rutas"
               Class="rz-mb-3" />

@if (IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 100%;" />
}

<RadzenDataGrid TItem="AreaRouteAdminDto" Data="@routes" @ref="grid" IsBusy="@IsLoading" AllowPaging="false" AllowVirtualization="true" AllowFiltering="true" AllowColumnResize="true"
                            AllowSorting="true" EditMode="DataGridEditMode.Single" RowCreate="@OnRowCreate" RowUpdate="@OnRowUpdate"
                            FilterMode="FilterMode.CheckBoxList" ClearFilterText="Limpiar" ApplyFilterText="Aplicar"
                            GridLines="DataGridGridLines.Both" AllowColumnPicking="false" ColumnsText="Columnas"
                             ColumnsShowingText="columnas mostradas" AllColumnsText="Todas"
                            EmptyText="No hay registros para mostrar." KeyProperty="Id">
                <HeaderTemplate>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                        <RadzenButton ButtonStyle="ButtonStyle.Success" Icon="add_circle" Text="Agregar" Click="@BeginCreate" Disabled="@(IsLoading || IsSaving || _routesToInsert.Count > 0)" />
                        <RadzenButton Icon="filter_alt_off" Text="Limpiar filtros" Click="@ClearFilters" Disabled="@(IsLoading || IsSaving)" />
                    </RadzenStack>
                </HeaderTemplate>
                <Columns>
                    <RadzenDataGridColumn TItem="AreaRouteAdminDto" Property="AreaName" Title="Área">
                        <Template Context="r">
                            @(r.AreaName ?? "Sin asignar")
                        </Template>
                        <EditTemplate Context="r">
                            <RadzenDropDown TValue="int?"
                                            Data="@areas"
                                            TextProperty="Name"
                                            ValueProperty="Id"
                                            Value="@GetAreaBuffer(r)"
                                            ValueChanged="@(v => SetAreaBuffer(r, v))"
                                            Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AreaRouteAdminDto" Property="ClientIdentifier" Title="Cliente">
                        <Template Context="r">
                            @(string.IsNullOrWhiteSpace(r.ClientIdentifier) ? "Sin asignar" : r.ClientIdentifier)
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AreaRouteAdminDto" Property="ApplicationName" Title="Aplicación">
                        <Template Context="r">
                            @(r.ApplicationName ?? "Sin asignar")
                        </Template>
                        <EditTemplate Context="r">
                            <RadzenDropDown TValue="int?"
                                            Data="@clients"
                                            TextProperty="Audience"
                                            ValueProperty="Id"
                                            Value="@GetClientBuffer(r)"
                                            ValueChanged="@(v => SetClientBuffer(r, v))"
                                            Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AreaRouteAdminDto" Property="Priority" Title="Prioridad">
                        <EditTemplate Context="r">
                            <RadzenNumeric TValue="int" Value="@GetPriorityBuffer(r)" ValueChanged="@(v => SetPriorityBuffer(r, v))"  Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AreaRouteAdminDto" Property="IsActiveText" Title="Activo">
                        <Template Context="r">
                            @(r.IsActive ? "Sí" : "No")
                        </Template>
                        <EditTemplate Context="r">
                            <RadzenCheckBox TValue="bool" Value="@GetActiveBuffer(r)" ValueChanged="@(v => SetActiveBuffer(r, v))" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AreaRouteAdminDto" Context="r" Filterable="false" Title="Acciones" Width="112px" TextAlign="TextAlign.Center">
                        <Template Context="r">
                            <RadzenButton Icon="edit" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Editar" AriaLabel="Editar" Click="@(args => EditRow(r))" @onclick:stopPropagation class="rz-mr-2" Disabled="@(IsLoading || IsSaving)" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Eliminar" AriaLabel="Eliminar" Click="@(args => DeleteRoute(r.Id))" @onclick:stopPropagation Disabled="@(IsLoading || IsSaving)" />
                        </Template>
                        <EditTemplate Context="r">
                            <RadzenButton Icon="save" ButtonStyle="ButtonStyle.Success" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Guardar" AriaLabel="Guardar" Click="@(args => ValidateAndSave(r))" Disabled="@(IsLoading || IsSaving)" />
                            <RadzenButton Icon="cancel" ButtonStyle="ButtonStyle.Danger" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" class="rz-ml-2" Title="Cancelar" AriaLabel="Cancelar" Click="@(args => CancelEditRow(r))" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                </Columns>
</RadzenDataGrid>
