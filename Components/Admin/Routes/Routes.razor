@page "/admin/routes"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Routes

<RadzenHeading Size="HeadingSize.H3"
               Text="Rutas"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <div class="rz-mb-3" style="display:flex; justify-content:flex-end; gap:0.5rem;">
                <RadzenButton Text="Nuevo" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@(() => BeginCreate())" />
            </div>

            <RadzenDataGrid TItem="Application.Admin.Dtos.AreaRouteAdminDto" Data="@routes" AllowPaging="true" PageSize="10" AllowFiltering="true" AllowColumnResize="true"
                FilterMode="FilterMode.CheckBoxList" AllowSorting="true" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                AllowColumnPicking="false" EmptyText="No hay registros para mostrar.">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="AreaName" Title="Área" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="ApplicationName" Title="Cliente" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="ReturnUrl" Title="ReturnUrl" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="Priority" Title="Prioridad" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Property="IsActive" Title="Activo" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.AreaRouteAdminDto" Context="r" Width="180px">
                        <Template Context="r">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Title="Editar" AriaLabel="Editar" Click="@(() => BeginEdit(r))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" class="rz-ml-2" Title="Eliminar" AriaLabel="Eliminar" Click="@(() => DeleteRoute(r.Id))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

            @if (editing)
            {
                <div class="rz-mt-3">
                    <RadzenCard>
                        <RadzenFieldset Text="@(editModel.Id == 0 ? "Crear ruta" : $"Editar ruta {editModel.Id}")">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="Área" />
                                    <RadzenDropDown Data="@areas" TextProperty="Name" ValueProperty="Id" @bind-Value="routeForm.AreaId" Placeholder="Área" Style="width: 100%" />
                                </RadzenStack>
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="Cliente" />
                                    <RadzenDropDown Data="@clients" TextProperty="ClientId" ValueProperty="Id" @bind-Value="routeForm.ClientId" Placeholder="Cliente" Style="width: 100%" />
                                </RadzenStack>
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="ReturnUrl" />
                                    <RadzenTextBox @bind-Value="routeForm.ReturnUrl" Placeholder="ReturnUrl" Style="width: 100%" />
                                </RadzenStack>
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="Prioridad" />
                                    <RadzenNumeric @bind-Value="routeForm.Priority" Placeholder="Prioridad" Min="1" Style="width: 180px" />
                                </RadzenStack>
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                    <RadzenCheckBox @bind-Value="routeForm.IsActive" />
                                    <RadzenLabel Text="Activo" />
                                </RadzenStack>
                                @if (!string.IsNullOrWhiteSpace(validationError))
                                {
                                    <RadzenAlert Severity="AlertSeverity.Warning">@validationError</RadzenAlert>
                                }
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                                    <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@OnSubmitRoute" />
                                    <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => CancelEdit())" />
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenFieldset>
                    </RadzenCard>
                </div>
            }
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
