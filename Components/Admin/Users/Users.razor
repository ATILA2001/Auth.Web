@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using Auth.Web.Application.Admin.Dtos
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Users

<RadzenHeading Size="HeadingSize.H3"
               Text="Usuarios"
               Class="rz-mb-3" />

@if (IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 100%;" />
}

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <RadzenDataGrid TItem="Application.Admin.Dtos.UserAdminDto" Data="@_vm.Users" @ref="grid" AllowPaging="true" PageSize="10" AllowFiltering="true" AllowColumnResize="true"
                            AllowSorting="true" EditMode="DataGridEditMode.Single" RowUpdate="@OnRowUpdate"
                            FilterMode="FilterMode.CheckBoxList" ClearFilterText="Limpiar" ApplyFilterText="Aplicar" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                            AllowColumnPicking="false" ColumnsText="Columnas" ColumnsShowingText="columnas mostradas" AllColumnsText="Todas" EmptyText="Sin registros"
                            AllowRowSelectOnRowClick="false">
                <HeaderTemplate>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                        <RadzenButton Icon="filter_alt_off" Text="Limpiar filtros" Click="@ClearFilters" Disabled="@(IsLoading || IsSaving)" />
                    </RadzenStack>
                </HeaderTemplate>
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.UserAdminDto" Property="FullName" Title="Usuario" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.UserAdminDto" Property="UserName" Title="CUIL" Width="130px" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.UserAdminDto" Property="Email" Title="Correo" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.UserAdminDto" Title="Roles" Filterable="false">
                        <Template Context="u">@string.Join(", ", u.Roles)</Template>
                        <EditTemplate Context="u">
                            <RadzenDropDown TValue="IEnumerable<string>"
                                            Data="@AllRoles"
                                            TextProperty="Name"
                                            ValueProperty="Name"
                                            Multiple="true"
                                            Value="@GetRolesBuffer(u)"
                                            ValueChanged="@(v => SetRolesBuffer(u, v?.ToList() ?? new()))"
                                            Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.UserAdminDto" Title="Áreas" Filterable="false">
                        <Template Context="u">@string.Join(", ", u.Areas)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.UserAdminDto" Title="Aplicaciones" Filterable="false">
                        <Template Context="u">@string.Join(", ", u.ClientIds)</Template>
                        <EditTemplate Context="u">
                            <RadzenDropDown TValue="IEnumerable<string>"
                                            Data="@AllClients"
                                            TextProperty="ClientId"
                                            ValueProperty="ClientId"
                                            Multiple="true"
                                            Value="@GetClientsBuffer(u)"
                                            ValueChanged="@(v => SetClientsBuffer(u, v?.ToList() ?? new()))"
                                            Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.UserAdminDto" Property="PermissionVersion" Title="Ver. Permisos" Width="120px" TextAlign="TextAlign.Center" Filterable="false" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.UserAdminDto" Context="u" Filterable="false" Title="Acciones" Width="148px" TextAlign="TextAlign.Center">
                        <Template Context="u">
                            <RadzenButton Icon="edit" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Editar roles/áreas" AriaLabel="Editar" Click="@(args => EditRow(u))" Disabled="@(IsLoading || IsSaving)" class="rz-mr-1" />
                            <RadzenButton Icon="manage_accounts" ButtonStyle="ButtonStyle.Info" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Overrides" AriaLabel="Overrides" Click="@(args => OpenUserOverridesDialog(u))" Disabled="@(IsLoading || IsSaving)" class="rz-mr-1" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Eliminar" AriaLabel="Eliminar" Click="@(args => DeleteUser(u.Id))" @onclick:stopPropagation Disabled="@(IsLoading || IsSaving)" />
                        </Template>
                        <EditTemplate Context="u">
                            <RadzenButton Icon="save" ButtonStyle="ButtonStyle.Success" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" Title="Guardar" AriaLabel="Guardar" Click="@(args => ValidateAndSave(u))" Disabled="@(IsLoading || IsSaving)" />
                            <RadzenButton Icon="cancel" ButtonStyle="ButtonStyle.Danger" ButtonSize="ButtonSize.Small" ButtonType="ButtonType.Button" class="rz-ml-2" Title="Cancelar" AriaLabel="Cancelar" Click="@(args => CancelEditRow(u))" Disabled="@(IsLoading || IsSaving)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
