@inherits LayoutComponentBase
@implements IDisposable

<RadzenTheme Theme="material-dark" />
<RadzenLayout>
    <!-- HEADER -->
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal"
                     AlignItems="AlignItems.Center"
                     Gap="0"
                     Class="rz-px-3">
            <!-- Toggle sidebar -->
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />

            <!-- Titulo -->
            <RadzenLink Text="ADMINISTRACIÓN" Path="/admin" Class="rz-ml-2"  />

            <!-- Bloque derecho: aplicativos + usuario + logout -->
            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         Class="rz-ml-auto"
                         Gap="0.75rem">
                <div style="position: relative; display: inline-block;">
                    <RadzenButton Text="Aplicaciones"
                                  Icon="grid_view"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="@ToggleAppSwitcher" />
                    @if (_appSwitcherOpen)
                    {
                        <div style="position: absolute; right: 0; top: calc(100% + 4px); min-width: 220px; z-index: 1000;
                                    background: var(--rz-base-background-color); border: 1px solid rgba(255,255,255,.15);
                                    border-radius: 4px; box-shadow: 0 4px 16px rgba(0,0,0,.5); overflow: hidden;">
                            @foreach (var client in clients)
                            {
                                <a href="@($"/connect/switch-app?clientId={Uri.EscapeDataString(client.ClientId)}")"
                                   style="display: block; padding: 10px 16px; text-decoration: none; color: var(--rz-text-color);"
                                   @onclick="@(() => _appSwitcherOpen = false)">@GetAppDisplayName(client)</a>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(CurrentUserName))
                {
                    <RadzenLabel Text="@CurrentUserName" />
                }
                <RadzenAppearanceToggle />

                @if (_canSubmitLogout && !string.IsNullOrEmpty(_antiforgeryFieldName) && !string.IsNullOrEmpty(_antiforgeryToken))
                {
                    <form method="post" action="/connect/logout">
                        <input type="hidden" name="@_antiforgeryFieldName" value="@_antiforgeryToken" />
                        <RadzenButton Icon="logout"
                                      Text="Salir"
                                      ButtonStyle="ButtonStyle.Danger"
                                      ButtonType="ButtonType.Submit" />
                    </form>
                }
                else
                {
                    <RadzenButton Icon="logout"
                                  Text="Salir"
                                  ButtonStyle="ButtonStyle.Danger"
                                  ButtonType="ButtonType.Button"
                                  Disabled="true" />
                }
            </RadzenStack>
        </RadzenStack>
    </RadzenHeader>

    <!-- SIDEBAR -->
    <RadzenSidebar @bind-Expanded="@sidebarExpanded">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="Áreas" Icon="domain" Path="/admin/areas" />
            <RadzenPanelMenuItem Text="Aplicaciones" Icon="apps" Path="/admin/clients" />
            <RadzenPanelMenuItem Text="Páginas" Icon="pageview" Path="/admin/pages" />
            <RadzenPanelMenuItem Text="Permisos" Icon="security" Path="/admin/permissions" />
            <RadzenPanelMenuItem Text="Roles" Icon="admin_panel_settings" Path="/admin/roles" />
            <RadzenPanelMenuItem Text="Rutas" Icon="alt_route" Path="/admin/routes" />
            <RadzenPanelMenuItem Text="Usuarios" Icon="group" Path="/admin/users" />
        </RadzenPanelMenu>
    </RadzenSidebar>

    <!-- DIALOG & NOTIFICATIONS HOSTS -->
    <RadzenDialog />
    <RadzenNotification />

    <!-- BODY -->
    <RadzenBody>
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>

</RadzenLayout>
