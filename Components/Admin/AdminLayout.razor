@inherits LayoutComponentBase

@inject NavigationManager NavigationManager
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject Auth.Web.Services.Abstractions.Admin.IAdminClientService AdminClientService

<RadzenLayout>
    <!-- HEADER -->
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal"
                     AlignItems="AlignItems.Center"
                     Gap="0"
                     Class="rz-px-3">
            <!-- Toggle sidebar -->
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />

            <!-- TĒtulo -->
            <RadzenLabel Text="Administraci¾n" Class="rz-ml-2" />

            <!-- Bloque derecho: aplicativos + usuario + logout -->
            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         Class="rz-ml-auto"
                         Gap="0.75rem">
                <RadzenDropDown TValue="string"
                                Data="@launchTargets"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedTarget"
                                Placeholder="Aplicativos"
                                Change="@OnLaunchTargetChanged" />

                @if (!string.IsNullOrWhiteSpace(CurrentUserName))
                {
                    <RadzenLabel Text="@CurrentUserName" />
                }

                <RadzenButton Icon="logout"
                              Text="Salir"
                              ButtonStyle="ButtonStyle.Secondary"
                              Click="@Logout" />
            </RadzenStack>
        </RadzenStack>
    </RadzenHeader>

    <!-- SIDEBAR -->
    <RadzenSidebar @bind-Expanded="@sidebarExpanded">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="Inicio" Icon="home" Path="/admin" />
            <RadzenPanelMenuItem Text="Usuarios" Icon="group" Path="/admin/users" />
            <RadzenPanelMenuItem Text="┴reas" Icon="domain" Path="/admin/areas" />
            <RadzenPanelMenuItem Text="Roles" Icon="security" Path="/admin/roles" />
            <RadzenPanelMenuItem Text="Aplicaciones" Icon="dns" Path="/admin/clients" />
            <RadzenPanelMenuItem Text="Rutas" Icon="device_hub" Path="/admin/routes" />
        </RadzenPanelMenu>
    </RadzenSidebar>

    <!-- BODY -->
    <RadzenBody>
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>


</RadzenLayout>

@code {
    bool sidebarExpanded = true;

    private List<Application.Admin.Dtos.ApplicationClientAdminDto> clients = new();
    private List<(string Text, string Value)> launchTargets = new();
    private string? selectedTarget;
    private string? CurrentUserName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        CurrentUserName = authState.User.Identity?.Name ?? string.Empty;

        clients = (await AdminClientService.GetClientsAsync()).ToList();
        launchTargets = clients
            .SelectMany(c => c.AllowedReturnUrls.Select(url => (
                Text: $"{c.ClientId} Ś {url}",
                Value: $"{c.ClientId}|{url}"
            )))
            .ToList();
    }

    private void OnLaunchTargetChanged(object? value)
    {
        var val = value as string;
        if (string.IsNullOrWhiteSpace(val)) return;
        var parts = val.Split('|', 2);
        if (parts.Length != 2) return;
        var clientId = parts[0];
        var url = parts[1];
        if (string.IsNullOrWhiteSpace(clientId) || string.IsNullOrWhiteSpace(url)) return;
        var launchUrl = $"/connect/launch?clientId={Uri.EscapeDataString(clientId)}&returnUrl={Uri.EscapeDataString(url)}";
        NavigationManager.NavigateTo(launchUrl, forceLoad: true);
    }

    private void Logout()
    {
        NavigationManager.NavigateTo("/connect/logout", true);
    }
}
