@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@using Auth.Web.Application.Admin.Dtos

<PageTitle>Usuarios</PageTitle>

<RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="2">
    <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1">
        <RadzenButton Text="Volver" Icon="arrow_back" ButtonStyle="Radzen.ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/admin"))" />
        <RadzenHeading Size="Radzen.HeadingSize.H3" Text="Usuarios" />
    </RadzenStack>

    <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1">
        <RadzenTextBox @bind-Value="search" Placeholder="Buscar" Style="width:320px" Change="@(args => Filter())" />
    </RadzenStack>

    <RadzenCard>
        <RadzenDataGrid TItem="UserAdminDto" Data="@filteredUsers" AllowPaging="true" PageSize="10">
            <Columns>
                <RadzenDataGridColumn TItem="UserAdminDto" Property="UserName" Title="Usuario" />
                <RadzenDataGridColumn TItem="UserAdminDto" Property="Email" Title="Correo" />
                <RadzenDataGridColumn TItem="UserAdminDto" Title="Roles">
                    <Template Context="u">@string.Join(", ", u.Roles)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UserAdminDto" Title="Áreas">
                    <Template Context="u">@string.Join(", ", u.Areas)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UserAdminDto" Context="u" Width="160px">
                    <Template Context="u">
                        <RadzenButton Text="Editar" Icon="manage_accounts" Size="Radzen.ButtonSize.Small" ButtonStyle="Radzen.ButtonStyle.Light" Click="@(args => BeginEdit(u))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>

    @if (SelectedUser is not null)
    {
        <RadzenCard>
            <RadzenFieldset Text="@($"Editar usuario {SelectedUser.UserName}")">
                <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="2">
                    <RadzenLabel Text="Roles" />
                    <RadzenDropDown Multiple="true" Data="@AllRoles" TextProperty="Name" ValueProperty="Name" @bind-Value="SelectedRoles" Style="width:100%" />
                    <RadzenLabel Text="Áreas" />
                    <RadzenDropDown Multiple="true" Data="@AllAreas" TextProperty="Name" ValueProperty="Id" @bind-Value="SelectedAreaIds" Style="width:100%" />
                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1">
                        <RadzenButton Text="Guardar" ButtonStyle="Radzen.ButtonStyle.Primary" Click="@(args => SaveUser())" />
                        <RadzenButton Text="Cancelar" ButtonStyle="Radzen.ButtonStyle.Light" Click="@(args => CancelEdit())" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenFieldset>
        </RadzenCard>
    }
</RadzenStack>
