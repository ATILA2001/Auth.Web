@page "/admin/users"
@using Auth.Web.Services.Admin
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager NavigationManager

<PageTitle>Usuarios</PageTitle>

<RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="2">
    <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1">
        <RadzenButton Text="Volver" Icon="arrow_back" ButtonStyle="Radzen.ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/admin"))" />
        <RadzenHeading Size="Radzen.HeadingSize.H3" Text="Usuarios" />
    </RadzenStack>

    <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1">
        <RadzenTextBox @bind-Value="search" Placeholder="Buscar" Style="width:320px" Change="@(args => Filter())" />
    </RadzenStack>

    <RadzenCard>
        <RadzenDataGrid TItem="UserItem" Data="@filteredUsers" AllowPaging="true" PageSize="10">
            <Columns>
                <RadzenDataGridColumn TItem="UserItem" Property="UserName" Title="Usuario" />
                <RadzenDataGridColumn TItem="UserItem" Property="Email" Title="Correo" />
                <RadzenDataGridColumn TItem="UserItem" Title="Roles">
                    <Template Context="u">
                        @string.Join(", ", u.Roles)
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UserItem" Context="u" Width="140px">
                    <Template Context="u">
                        <RadzenButton Text="Roles" Icon="manage_accounts" Size="Radzen.ButtonSize.Small" ButtonStyle="Radzen.ButtonStyle.Light" Click="@(args => EditRoles(u))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>

    @if (editUser is not null)
    {
        <RadzenCard>
            <RadzenFieldset Text="@($"Editar roles de {editUser.UserName}")">
                <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="1">
                    @foreach (var r in allRoles)
                    {
                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="Radzen.AlignItems.Center" Gap="1">
                            <RadzenCheckBox Value="@selectedRoles.Contains(r)" Change="@((bool? v) => ToggleRole(r, v == true))" />
                            <RadzenLabel Text="@r" />
                        </RadzenStack>
                    }
                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1">
                        <RadzenButton Text="Guardar" ButtonStyle="Radzen.ButtonStyle.Primary" Click="@(_ => SaveUserRoles())" />
                        <RadzenButton Text="Cancelar" ButtonStyle="Radzen.ButtonStyle.Light" Click="@(_ => CancelEdit())" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenFieldset>
        </RadzenCard>
    }
</RadzenStack>
