@page "/admin/actions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Actions

<RadzenHeading Size="HeadingSize.H3"
               Text="Acciones de Permiso"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <div class="rz-mb-3" style="display:flex; justify-content:flex-end; gap:0.5rem;">
                <RadzenButton Text="Nuevo" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@BeginCreate" />
            </div>

            <RadzenDataGrid TItem="Application.Admin.Dtos.ActionPermissionAdminDto" Data="@actions" AllowPaging="true" PageSize="10" AllowFiltering="true" AllowColumnResize="true"
                FilterMode="FilterMode.CheckBoxList" AllowSorting="true" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                AllowColumnPicking="false" EmptyText="No hay registros para mostrar.">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ActionPermissionAdminDto" Property="Name" Title="Nombre" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ActionPermissionAdminDto" Property="UsageCount" Title="Usos" Width="100px" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ActionPermissionAdminDto" Context="a" Width="160px">
                        <Template Context="a">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Title="Editar" AriaLabel="Editar" Click="@(() => BeginEdit(a))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" class="rz-ml-2" Title="Eliminar" AriaLabel="Eliminar" Click="@(() => DeleteAction(a.Id))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

            @if (editing)
            {
                <div class="rz-mt-3">
                    <RadzenCard>
                        <RadzenFieldset Text="@(editModel.Id == 0 ? "Nueva acción" : $"Editar acción {editModel.Name}")">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="Nombre" />
                                    <RadzenTextBox @bind-Value="actionForm.Name" Placeholder="Nombre de la acción" Style="width: 300px" />
                                </RadzenStack>
                                @if (!string.IsNullOrWhiteSpace(validationError))
                                {
                                    <RadzenAlert Severity="AlertSeverity.Warning">@validationError</RadzenAlert>
                                }
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                                    <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@OnSubmitAction" />
                                    <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@CancelEdit" />
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenFieldset>
                    </RadzenCard>
                </div>
            }
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
