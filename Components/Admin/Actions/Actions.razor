@page "/admin/actions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Actions

<RadzenHeading Size="HeadingSize.H3"
               Text="Acciones de Permiso"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <div class="rz-mb-3">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                        <RadzenLabel Text="Acción" />
                        <RadzenTextBox @bind-Value="actionForm.Name" Placeholder="Nueva acción (ej: View, Edit, Delete)" Style="width: 300px" />
                    </RadzenStack>
                    <RadzenButton Text="Agregar" Icon="add" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@OnSubmitAction" />
                </RadzenStack>
            </div>

            <RadzenDataGrid TItem="Application.Admin.Dtos.ActionPermissionAdminDto" Data="@actions" @ref="grid" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="10" RowUpdate="@OnRowUpdate" AllowFiltering="true" AllowColumnResize="true"
    FilterMode="FilterMode.CheckBoxList" AllowSorting="true" ClearFilterText="Limpiar" ApplyFilterText="Aplicar" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
    AllowColumnPicking="false" ColumnsText="Columnas" ColumnsShowingText="columnas mostradas" AllColumnsText="Todas" EmptyText="Sin registros">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ActionPermissionAdminDto" Property="Name" Title="Nombre">
                        <EditTemplate Context="a">
                            <RadzenTextBox @bind-Value="a.Name" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ActionPermissionAdminDto" Property="UsageCount" Title="Usos" Width="100px" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.ActionPermissionAdminDto" Context="a" Width="160px">
                        <Template Context="a">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Title="Editar" AriaLabel="Editar" Click="@(args => grid.EditRow(a))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" class="rz-ml-2" Title="Eliminar" AriaLabel="Eliminar" Click="@(args => DeleteAction(a.Id))" />
                        </Template>
                        <EditTemplate Context="a">
                            <RadzenButton Icon="save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Title="Guardar" AriaLabel="Guardar" Click="@(args => grid.UpdateRow(a))" />
                            <RadzenButton Icon="cancel" Size="ButtonSize.Small" class="rz-ml-2" Title="Cancelar" AriaLabel="Cancelar" Click="@(args => grid.CancelEditRow(a))" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
