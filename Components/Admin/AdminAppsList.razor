@using Auth.Web.Services.Admin
@using Auth.Web.Domain.Entities
@inject IRoutingAdminService RoutingSvc

@* Componente compacto para NavMenu (solo Admin) *@

@if (error is not null)
{
    <div class="nav-item px-3 text-danger small">Error cargando aplicativos: @error</div>
}
else if (loading)
{
    <div class="nav-item px-3 small text-muted">Cargando aplicativos...</div>
}
else
{
    <div class="nav-item px-3">
        <span class="nav-link disabled small text-uppercase fw-semibold">Aplicativos (@rules.Count(r => r.IsActive) activos)</span>
    </div>

    @if (areas.Count == 0)
    {
        <div class="nav-item px-3 text-muted small">Sin ßreas configuradas</div>
    }
    else if (rules.Count == 0)
    {
        <div class="nav-item px-3 text-muted small">Sin reglas de redirecciˇn</div>
    }
    else if (!rules.Any(r => r.IsActive))
    {
        <div class="nav-item px-3 text-muted small">Todas las reglas estßn inactivas</div>
    }
    else
    {
        @foreach (var r in rules.Where(r => r.IsActive).OrderBy(r => r.Priority))
        {
            var areaName = areas.FirstOrDefault(a => a.Id == r.AreaId)?.Name ?? $"┴rea {r.AreaId}";
            <div class="nav-item px-3">
                <a class="nav-link d-flex justify-content-between align-items-center" href="@r.ReturnUrl" target="_blank" rel="noopener noreferrer">
                    <span>@areaName <small class="text-body-secondary">(@r.ClientId)</small></span>
                    <span class="badge text-bg-secondary">@r.Priority</span>
                </a>
            </div>
        }
    }
}

@code {
    private List<Area> areas = new();
    private List<AreaRoute> rules = new();
    private bool loading = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            (areas, rules) = await RoutingSvc.GetAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
