@using Auth.Web.Services.Admin
@using Auth.Web.Domain.Entities
@inject IRoutingAdminService RoutingSvc

<div class="card">
    <div class="card-header">Aplicativos disponibles</div>
    <div class="card-body">
        <p class="text-muted">Seleccione un aplicativo para navegar.</p>
        @if (areas.Count == 0 || rules.Count == 0)
        {
            <div class="alert alert-warning">No hay reglas configuradas o no hay áreas.</div>
        }
        else
        {
            <div class="list-group">
                @foreach (var r in rules.Where(r => r.IsActive).OrderBy(r => r.Priority))
                {
                    var areaName = areas.First(a => a.Id == r.AreaId).Name;
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="@r.ReturnUrl" target="_blank">
                        <span>
                            <strong>@areaName</strong>
                            <small class="text-body-secondary ms-2">(@r.ClientId)</small>
                        </span>
                        <span class="badge text-bg-secondary">@r.Priority</span>
                    </a>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<Area> areas = new();
    private List<AreaRoute> rules = new();

    protected override async Task OnInitializedAsync()
    {
        (areas, rules) = await RoutingSvc.GetAsync();
    }
}
