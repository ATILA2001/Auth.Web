@page "/admin/roles"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Roles

<RadzenHeading Size="HeadingSize.H3"
               Text="Roles"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <div class="rz-mb-3" style="display:flex; justify-content:flex-end; gap:0.5rem;">
                <RadzenButton Text="Nuevo" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@BeginCreate" />
            </div>

            <RadzenDataGrid TItem="Application.Admin.Dtos.RoleAdminDto" Data="@roles" AllowPaging="true" PageSize="10" AllowFiltering="true" AllowColumnResize="true" FilterMode="FilterMode.CheckBoxList"
                AllowSorting="true" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                AllowColumnPicking="false" EmptyText="No hay registros para mostrar.">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RoleAdminDto" Property="Name" Title="Nombre" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RoleAdminDto" Property="UserCount" Title="Usuarios" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RoleAdminDto" Context="r" Width="150px">
                        <Template Context="r">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Title="Editar" AriaLabel="Editar" Click="@(() => BeginEdit(r))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" class="rz-ml-2" Title="Eliminar" AriaLabel="Eliminar" Click="@(() => DeleteRole(r.Id))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

            @if (editing)
            {
                <div class="rz-mt-3">
                    <RadzenCard>
                        <RadzenFieldset Text="@(editModel.Id == "" ? "Nuevo rol" : $"Editar rol {editModel.Name}")">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="Nombre" />
                                    <RadzenTextBox @bind-Value="roleForm.Name" Placeholder="Nombre del rol" Style="width: 300px" />
                                </RadzenStack>
                                @if (!string.IsNullOrWhiteSpace(validationError))
                                {
                                    <RadzenAlert Severity="AlertSeverity.Warning">@validationError</RadzenAlert>
                                }
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                                    <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@OnSubmitRole" />
                                    <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@CancelEdit" />
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenFieldset>
                    </RadzenCard>
                </div>
            }
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
