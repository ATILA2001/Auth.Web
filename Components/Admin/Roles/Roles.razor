@page "/admin/roles"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Roles

<RadzenHeading Size="HeadingSize.H3"
               Text="Roles"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">
            <div class="rz-mb-3">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                        <RadzenLabel Text="Rol" />
                        <RadzenTextBox @bind-Value="roleForm.Name" Placeholder="Nuevo rol" Style="width: 300px" />
                    </RadzenStack>
                    <RadzenButton Text="Agregar" Icon="add" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@OnSubmitRole" />
                </RadzenStack>
            </div>

            <RadzenDataGrid TItem="Application.Admin.Dtos.RoleAdminDto" Data="@roles" AllowPaging="true" PageSize="10" AllowFiltering="true" AllowColumnResize="true" FilterMode="FilterMode.CheckBoxList"
                AllowSorting="true" ClearFilterText="Limpiar" ApplyFilterText="Aplicar" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                AllowColumnPicking="false" ColumnsText="Columnas" ColumnsShowingText="columnas mostradas" AllColumnsText="Todas" EmptyText="Sin registros">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RoleAdminDto" Property="Name" Title="Nombre" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RoleAdminDto" Property="UserCount" Title="Usuarios" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RoleAdminDto" Context="r" Width="120px">
                        <Template Context="r">
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Title="Eliminar" AriaLabel="Eliminar" Click="@(() => DeleteRole(r.Id))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
