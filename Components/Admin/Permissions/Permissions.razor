@page "/admin/permissions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Permissions

<RadzenHeading Size="HeadingSize.H3"
               Text="Permisos de Página"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">

            @* Filtros *@
            <div class="rz-mb-3">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Wrap="FlexWrap.Wrap">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                        <RadzenLabel Text="Filtrar por Rol" />
                        <RadzenDropDown TValue="string" 
                                        Data="@roles" 
                                        TextProperty="Name" 
                                        ValueProperty="Id" 
                                        @bind-Value="filterRoleId" 
                                        Placeholder="Todos los roles"
                                        AllowClear="true"
                                        Style="width: 200px" />
                    </RadzenStack>
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                        <RadzenLabel Text="Filtrar por Página" />
                        <RadzenDropDown TValue="int?" 
                                        Data="@pages" 
                                        TextProperty="Name" 
                                        ValueProperty="Id" 
                                        @bind-Value="filterPageId" 
                                        Placeholder="Todas las páginas"
                                        AllowClear="true"
                                        Style="width: 200px" />
                    </RadzenStack>
                    <RadzenButton Text="Filtrar" Icon="filter_alt" Click="@ApplyFilter" />
                    <RadzenButton Text="Limpiar" Icon="clear" ButtonStyle="ButtonStyle.Light" Click="@ClearFilter" />
                </RadzenStack>
            </div>

            @* Formulario de creación *@
            @if (editing)
            {
                <div class="rz-mb-3 rz-p-3" style="background: var(--rz-base-100); border-radius: var(--rz-border-radius);">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                        <RadzenLabel Text="Asignar nuevo permiso" Style="font-weight: bold;" />

                        @if (!string.IsNullOrWhiteSpace(validationError))
                        {
                            <RadzenAlert Severity="AlertSeverity.Warning" Style="width:100%">@validationError</RadzenAlert>
                        }

                        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                <RadzenLabel Text="Rol" />
                                <RadzenDropDown TValue="string" 
                                                Data="@roles" 
                                                TextProperty="Name" 
                                                ValueProperty="Id" 
                                                @bind-Value="selectedRoleId" 
                                                Style="width: 180px" />
                            </RadzenStack>
                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                <RadzenLabel Text="Página" />
                                <RadzenDropDown TValue="int" 
                                                Data="@pages" 
                                                TextProperty="Name" 
                                                ValueProperty="Id" 
                                                @bind-Value="selectedPageId" 
                                                Style="width: 180px" />
                            </RadzenStack>
                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                <RadzenLabel Text="Acción" />
                                <RadzenDropDown TValue="int" 
                                                Data="@actions" 
                                                TextProperty="Name" 
                                                ValueProperty="Id" 
                                                @bind-Value="selectedActionId" 
                                                Style="width: 180px" />
                            </RadzenStack>
                        </RadzenStack>

                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" Click="@SavePermission" />
                            <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@CancelEdit" />
                        </RadzenStack>
                    </RadzenStack>
                </div>
            }
            else
            {
                <div class="rz-mb-3">
                    <RadzenButton Text="Asignar Permiso" ButtonStyle="ButtonStyle.Primary" Click="@BeginCreate" />
                </div>
            }

            @* Grid de permisos *@
            <RadzenDataGrid TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Data="@permissions" @ref="grid" AllowPaging="true" PageSize="15" AllowSorting="true" AllowFiltering="true" AllowColumnResize="true"
                FilterMode="FilterMode.CheckBoxList" ClearFilterText="Limpiar" ApplyFilterText="Aplicar" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                AllowColumnPicking="false" ColumnsText="Columnas" ColumnsShowingText="columnas mostradas" AllColumnsText="Todas">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Property="RoleName" Title="Rol" Width="150px" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Property="PageName" Title="Página" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Property="PageUrl" Title="URL" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Property="ActionName" Title="Acción" Width="120px" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Context="p" Width="80px">
                        <Template Context="p">
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(args => DeletePermission(p.Id))" Disabled="@editing" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
