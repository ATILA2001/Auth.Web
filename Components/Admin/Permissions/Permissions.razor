@page "/admin/permissions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Permissions

<RadzenHeading Size="HeadingSize.H3"
               Text="Permisos de Pßgina"
               Class="rz-mb-3" />

<RadzenRow>
    <RadzenColumn Size="12" SizeMd="10" SizeLg="10" OffsetMd="1" OffsetLg="1">
        <RadzenCard Class="rz-shadow-3 rz-p-3">

            @* Formulario de creaciˇn *@
            @if (editing)
            {
                <div class="rz-mb-3 rz-p-3" style="background: var(--rz-base-100); border-radius: var(--rz-border-radius);">
                    <RadzenTemplateForm TItem="PermissionsFormModel" Data="@permissionForm">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                            <RadzenLabel Text="Asignar nuevo permiso" Style="font-weight: bold;" />

                            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="Rol" Component="roleDrop" />
                                    <RadzenDropDown Name="roleDrop" TValue="string"
                                                    Data="@roles"
                                                    TextProperty="Name"
                                                    ValueProperty="Id"
                                                    @bind-Value="permissionForm.RoleId"
                                                    Style="width: 180px" />
                                    <RadzenRequiredValidator Component="roleDrop" Text="Requerido" />
                                </RadzenStack>
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="Pßgina" Component="pageDrop" />
                                    <RadzenDropDown Name="pageDrop" TValue="int"
                                                    Data="@pages"
                                                    TextProperty="Name"
                                                    ValueProperty="Id"
                                                    @bind-Value="permissionForm.PageId"
                                                    Style="width: 180px" />
                                    <RadzenRequiredValidator Component="pageDrop" Text="Requerido" />
                                </RadzenStack>
                                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                                    <RadzenLabel Text="Acciˇn" Component="actionDrop" />
                                    <RadzenDropDown Name="actionDrop" TValue="int"
                                                    Data="@actions"
                                                    TextProperty="Name"
                                                    ValueProperty="Id"
                                                    @bind-Value="permissionForm.ActionId"
                                                    Style="width: 180px" />
                                    <RadzenRequiredValidator Component="actionDrop" Text="Requerido" />
                                </RadzenStack>
                            </RadzenStack>

                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@OnSubmitPermission" />
                                <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@CancelEdit" />
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenTemplateForm>
                </div>
            }
            else
            {
                <div class="rz-mb-3">
                    <RadzenButton Text="Agregar" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@BeginCreate" />
                </div>
            }

            @* Grid de permisos *@
            <RadzenDataGrid TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Data="@permissions" @ref="grid" AllowPaging="true" PageSize="15" AllowSorting="true" AllowFiltering="true" AllowColumnResize="true"
                FilterMode="FilterMode.CheckBoxList" ClearFilterText="Limpiar" ApplyFilterText="Aplicar" GridLines="DataGridGridLines.Vertical" Style="height: 60vh"
                AllowColumnPicking="false" ColumnsText="Columnas" ColumnsShowingText="columnas mostradas" AllColumnsText="Todas" EmptyText="Sin registros">
                <Columns>
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Property="RoleName" Title="Rol" Width="150px" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Property="PageName" Title="Pßgina" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Property="PageUrl" Title="URL" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Property="ActionName" Title="Acciˇn" Width="120px" />
                    <RadzenDataGridColumn TItem="Application.Admin.Dtos.RolePagePermissionAdminDto" Context="p" Width="80px">
                        <Template Context="p">
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Title="Eliminar" AriaLabel="Eliminar" Click="@(args => DeletePermission(p.Id))" Disabled="@editing" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
