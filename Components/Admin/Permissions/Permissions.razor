@page "/admin/permissions"
@using Microsoft.AspNetCore.Authorization
@using Auth.Web.Application.Admin.Dtos
@attribute [Authorize(Roles = "Admin")]
@layout Auth.Web.Components.Admin.AdminLayout
@namespace Auth.Web.Components.Admin.Permissions

<RadzenHeading Size="HeadingSize.H3" Text="Permisos de área" Class="rz-mb-3" />

@if (IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 100%;" />
}

<RadzenRow Gap="1rem">

    <!-- Panel izquierdo: lista de áreas -->
    <RadzenColumn Size="12" SizeMd="3">
        <RadzenCard Class="rz-shadow-2 rz-p-3">
            <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-mb-2">Área</RadzenText>
            <RadzenListBox TValue="int"
                           Data="@_vm.Areas"
                           TextProperty="Name"
                           ValueProperty="Id"
                           Value="@_selectedAreaId"
                           Change="@OnAreaSelected"
                           Style="width:100%; height:calc(60vh - 60px);"
                           Class="rz-border-radius" />
        </RadzenCard>
    </RadzenColumn>

    <!-- Panel derecho: matriz de permisos -->
    <RadzenColumn Size="12" SizeMd="9">
        <RadzenCard Class="rz-shadow-2 rz-p-3">
            @if (_selectedAreaId == 0)
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
                    Seleccione un área para ver y editar sus permisos.
                </RadzenAlert>
            }
            else if (IsLoadingMatrix)
            {
                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width:100%" />
            }
            else if (!_selectedAreaHasClient)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Wrap="FlexWrap.Wrap">
                        <RadzenIcon Icon="link_off" />
                        <span>
                            El área <strong>@_selectedAreaName</strong> no tiene una aplicación asignada.
                            Para poder configurar sus permisos, primero asígnale una aplicación desde la sección correspondiente.
                        </span>
                        <a href="/admin/routes" style="color:var(--rz-warning-dark); font-weight:600; text-decoration:underline;">Ir a Rutas →</a>
                    </RadzenStack>
                </RadzenAlert>
            }
            else
            {
                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.SpaceBetween"
                             Class="rz-mb-3">
                    <RadzenText TextStyle="TextStyle.H6">@_selectedAreaName</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-disabled-color)">
                        Los cambios se guardan automáticamente.
                    </RadzenText>
                </RadzenStack>

                @if (!_vm.MatrixRows.Any())
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false">
                        No hay páginas registradas en el sistema.
                    </RadzenAlert>
                }
                else
                {
                    @foreach (var group in _vm.MatrixRows.GroupBy(r => r.ClientName).OrderBy(g => g.Key))
                    {
                        <RadzenText TextStyle="TextStyle.Overline"
                                    Class="rz-mt-3 rz-mb-1"
                                    Style="color:var(--rz-text-secondary-color)">
                            Aplicación: <strong>@group.Key</strong>
                        </RadzenText>

                        <div class="rz-mb-4" style="overflow-x:auto">
                            <table class="rz-grid-table rz-grid-table-striped"
                                   style="width:100%; border-collapse:collapse">
                                <thead>
                                    <tr>
                                        <th class="rz-text-align-left rz-p-2"
                                            style="min-width:160px; border-bottom:2px solid var(--rz-grid-header-border-color)">
                                            Página
                                        </th>
                                        <th class="rz-text-align-left rz-p-2"
                                            style="min-width:180px; border-bottom:2px solid var(--rz-grid-header-border-color)">
                                            URL
                                        </th>
                                        @foreach (var action in _vm.Actions)
                                        {
                                            <th class="rz-text-align-center rz-p-2"
                                                style="width:90px; border-bottom:2px solid var(--rz-grid-header-border-color)">
                                                @action.Name
                                            </th>
                                        }
                                        <th class="rz-text-align-center rz-p-2"
                                            style="width:90px; border-bottom:2px solid var(--rz-grid-header-border-color); font-style:italic">
                                            Todos
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in group)
                                    {
                                        <tr>
                                            <td class="rz-p-2">@row.PageName</td>
                                            <td class="rz-p-2"
                                                style="max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap"
                                                title="@row.PageUrl">
                                                @row.PageUrl
                                            </td>
                                            @foreach (var action in _vm.Actions)
                                            {
                                                <td class="rz-text-align-center rz-p-2">
                                                    <RadzenCheckBox TValue="bool"
                                                                    Value="@row.IsEnabled(action.Id)"
                                                                    Change="@(v => TogglePermissionAsync(row, action.Id, v))"
                                                                    Disabled="@IsSaving" />
                                                </td>
                                            }
                                            <td class="rz-text-align-center rz-p-2">
                                                <RadzenCheckBox TValue="bool"
                                                                Value="@row.AllActionsEnabled(_vm.Actions)"
                                                                Change="@(v => ToggleAllAsync(row, v))"
                                                                Disabled="@IsSaving" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            }
        </RadzenCard>
    </RadzenColumn>

</RadzenRow>

