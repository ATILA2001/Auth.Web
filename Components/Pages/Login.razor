@page "/login"

@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Mvc

@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<h1>Ingreso</h1>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @ErrorMessage
    </div>
}

<EditForm Model="LoginModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="userName" class="form-label">Usuario</label>
        <InputText id="userName" class="form-control" @bind-Value="LoginModel.UserName" />
        <ValidationMessage For="() => LoginModel.UserName" />
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <InputText id="password" type="password" class="form-control" @bind-Value="LoginModel.Password" />
        <ValidationMessage For="() => LoginModel.Password" />
    </div>

    <div class="mb-3">
        <label for="clientId" class="form-label">ClientId</label>
        <InputText id="clientId" class="form-control" @bind-Value="LoginModel.ClientId" />
        <ValidationMessage For="() => LoginModel.ClientId" />
    </div>

    <div class="mb-3">
        <label for="returnUrl" class="form-label">ReturnUrl</label>
        <InputText id="returnUrl" class="form-control" @bind-Value="LoginModel.ReturnUrl" />
        <ValidationMessage For="() => LoginModel.ReturnUrl" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@IsLoading">
        @(IsLoading ? "Ingresando..." : "Ingresar")
    </button>
</EditForm>

@code {
    private readonly LoginRequest LoginModel = new();
    private bool IsLoading;
    private string? ErrorMessage;

    private async Task HandleValidSubmit()
    {
        ErrorMessage = null;
        IsLoading = true;

        try
        {
            var response = await Http.PostAsJsonAsync("/connect/login", LoginModel);

            if (response.IsSuccessStatusCode)
            {
                var loginResponse = await response.Content.ReadFromJsonAsync<LoginResult>();

                if (loginResponse is null || string.IsNullOrWhiteSpace(loginResponse.Redirect))
                {
                    ErrorMessage = "La respuesta del servidor es inválida.";
                }
                else
                {
                    Navigation.NavigateTo(loginResponse.Redirect, forceLoad: true);
                }
            }
            else
            {
                var problem = await response.Content.ReadFromJsonAsync<ProblemDetails>();
                ErrorMessage = problem?.Detail ?? problem?.Title ?? "No se pudo iniciar sesión. Verificá tus datos e intentá nuevamente.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Ocurrió un error al iniciar sesión: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private sealed class LoginRequest
    {
        [Required]
        public string UserName { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        [Required]
        public string ClientId { get; set; } = string.Empty;

        [Required]
        public string ReturnUrl { get; set; } = string.Empty;
    }

    private sealed class LoginResult
    {
        public string? Redirect { get; set; }
    }
}
