<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">   
        <AuthorizeView>
            <Authorized>                
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Cerrar sesión
                        </button>
                    </form>
                </div>
                @if (context.User.IsInRole("Admin"))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/admin">
                            <span class="bi bi-pencil-square" aria-hidden="true"></span> Administración
                        </NavLink>
                    </div>
                    <div class="mt-2 mb-2 border-top"></div>

                    @* Inicio listado aplicativos *@
                    <div class="nav-item px-3">
                        <span class="nav-link disabled small text-uppercase fw-semibold">Aplicativos</span>
                    </div>
                    @if (appsError is not null)
                    {
                        <div class="nav-item px-3 text-danger small">Error: @appsError</div>
                    }
                    else if (appsLoading)
                    {
                        <div class="nav-item px-3 small text-muted">Cargando aplicativos...</div>
                    }
                    else if (areas.Count == 0)
                    {
                        <div class="nav-item px-3 small text-muted">Sin áreas</div>
                    }
                    else if (rules.Count == 0)
                    {
                        <div class="nav-item px-3 small text-muted">Sin reglas de redirección</div>
                    }
                    else if (activeCount == 0)
                    {
                        <div class="nav-item px-3 small text-muted">Todas las reglas inactivas</div>
                    }
                    else
                    {
                        @foreach (var r in rules.Where(r => r.IsActive).OrderBy(r => r.Priority))
                        {
                           
                            <div class="nav-item px-3">
                                <a class="nav-link d-flex justify-content-between align-items-center" href="@r.ReturnUrl" target="_blank" rel="noopener noreferrer">
                                    <span><small class="text-body-secondary">@r.ClientId</small></span>
                                    
                                </a>
                            </div>
                        }
                    }
                    @* Fin listado aplicativos *@

                    <div class="mt-2 mb-2 border-top"></div>
                }
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Registrarse
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Iniciar sesión
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

